		Configs: {
			ConfigurationsIndividual: {
				DisplayName: Локальная конфигурация

				Headers: {
					Audio: Аудио
					Visual: Графика
				}

				NoPain: {
					Tooltip: Отключает озвучивание некоторых предметов
					Label: Отключить звуки предметов
				}

				NoMessage: {
					Tooltip: Отключает отображение некоторых сообщений в чате от боссов/определённых предметов. Обратите внимание, что сообщения о статусе мировых событий по-прежнему будут отображаться
					Label: Отключить сообщения в чате
				}

				NoShake: {
					Tooltip: Отключает дрожание экрана, которое вызывают некоторые предметы мода
					Label: Отключить дрожание экрана
				}

				ShakeAmount: {
					Tooltip: Измените интенсивность эффекта дрожания экрана; установите значение 0, чтобы отключить его (по умолчанию — 5)
					Label: Интенсивность дрожания экрана
				}
			}

			ConfigurationsGlobal: {
				DisplayName: Глобальная конфигурация

				Headers: {
					EnemyMisc: Другое: враги
					EnemySpawning: Появление врагов
					GenMisc: Другое
					// AprilFools: April Fools Events
				}

				PreventBossStorm: {
					Tooltip: Это предотвратит изменение погоды боссами в моде, когда они живы
					Label: Отключить изменение погоды боссов
				}

				PreventBuffedDerps: {
					Tooltip: Это предотвратит значительное увеличение характеристик тупоголовов после поражении Плантеры
					Label: Отключить улучшения тупоголовов
				}

				StormBossSkipsPlant: {
					Tooltip: Включите, чтобы победа над Перегруженным скандроном привела ко всему тому, что было бы после поражения Плантеры
					Label: Перегруженный скандрон заменяет Плантеру
				}

				NoMoonling4U: {
					Tooltip: Предотвращает естественное появление луноголовов в космосе после поражения Лунного лорда; их по-прежнему можно призвать с помощью ​​«Ядра луноголова»
					Label: Отключить естественное появление луноголовов
				}

				PreventPillarEnemies: {
					Tooltip: Это предотвратит появление новых врагов у небесных башен
					Label: Отключить новых врагов небесных башен
				}

				NoChestforu: {
					Tooltip: Это предотвратит появление дополнительных сундуков в гранитном, мраморном и грибном биомах в случае конфликтов модов
					Label: Отключить дополнительные сундуки
				}

				NoScaryCurse: {
					Tooltip: Это предотвратит активацию «Проклятия храма», если в вашем инвентаре находится модовый храмовый предмет
					Label: Отключить проклятие храма
				}

				GlassSoWeak: {
					Tooltip: Это позволит стеклянному оружию и инструментам в этом моде разбиваться с одного удара, для шуточного эффекта
					Label: Стеклянные предметы разбиваются при ударе
				}

				AFTouchGrass: {
					// Tooltip: Allows you to craft the Special Grass Seed to activate Touch Grass Mode, disable this config to deactivate Touch Grass Mode in your world
					// Label: (2025) Touch Grass Mode (Very Unbalanced and not playtested)
				}

				AFGacha: {
					// Tooltip: This will make the Gacha Pain Tokens drop and generate in chests, allowing you to pull for the Golden Pain Mask, pity count and cooldowns won't reset if disabled
					// Label: (2026) Golden Pain Mask Gacha System
				}
			}
		}

