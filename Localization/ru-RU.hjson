//Note for mod translators, I will not be adding anything else to this list that is missing, I did not want to create a localisation file in the first place but sadly I was forced to, so there is a lot of text in this mod not present in this file but rather hardcoded into the mod.
Mods: {
	StormDiversMod: {
		"Keybinds.Armor Special Ability.DisplayName": Способность комплекта брони

		GameTips: {
			StormTip0: Возникают трудности с победой над боссами? Просто снизьте их здоровье до 0, поддерживая при этом своё здоровье выше 0.
			StormTip1: Вы сможете избежать вражеских атак, если будете уклоняться.
			StormTip2: Вы можете прыгать, нажимая кнопку прыжка.
			StormTip3: Если вы хотите наносить урон, используйте оружие, которое наносит урон.
			StormTip4: Постоянно умираете? Проблемы с навыками!
			StormTip5: Error 404, подсказка не найдена!
			Stormtip6: Смерть — эффективный способ восстановить здоровье, если только вы не играете на хардкоре.
			Stormtip7: Вы можете строить, ставя блоки.
			Stormtip8: Вы можете ломать блоки, ломая их.
			Stormtip9: Влезьте в Храм джунглей раньше положенного и обчистите его, осмельтесь, сделайте это!
			Stormtip10: Заманите тупоголова в Мерцание, они обожают ванны с мерцанием
		}

		//Achievements Mod
		Achievements: {
