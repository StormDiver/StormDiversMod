			}

			GalacticBat: {
				DisplayName: Галактический бейсболист
				Tooltip:
					'''
					Удары по врагам заряжают биту до 10 раз, но за один удар можно получить только один заряд
					Как только бита полностью зарядится, нажмите ПКМ, чтобы нанести мощный удар, который всегда наносит критический урон и снижает защиту на 15 ед.
					Мощный удар также накладывает дебафф «сСломаный», из-за которого враги получают на 10% больше урона и получают 10 ед. урона в секунду в течение 5 секунд
					Мощный удар не нужно будет перезаряжать, если во время удара ни один враг не был поражён
					«ПРАВИЛА... СОЗДАНЫ ДЛЯ ТОГО, ЧТОБЫ ИХ НАРУШАТЬ!»
					'''
			}

			IOUBannerItem: {
